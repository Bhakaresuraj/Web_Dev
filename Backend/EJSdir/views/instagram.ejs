<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram page</title>
    <!-- <style>
        img{
            height:200px;
            width:200px;

        }
    </style> -->
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <h1>Welcome..! @ <%= data.name %>
    </h1>
    <button>Follow</button>
    <button>Message</button>
    <p> Followers :
        <%= data.followers %> &nbsp &nbsp&nbsp&nbsp
            Following :
            <%= data.following %>
    </p>
    <hr>

    <% for(let post of data.posts){ %>
        <img src="<%= post.image %>" alt="">
        <p>Likes : <%= post.likes %>
                &nbsp &nbsp &nbsp &nbsp &nbspcomments :<%= post.comments%>
        </p>
        <% } %>


</body>
<script src="/script.js"></script>

</html>