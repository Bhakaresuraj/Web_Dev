<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Chats</title>
    <style>
        table,
        tr,
        td,
        th {
            border: 1px solid black;
        }
    </style>
</head>

<body>
    <table>
        <tr>
            <th>ID</th>
            <th>Message</th>
            <th>from</th>
            <th>to</th>
            <th>Created_at</th>
        </tr>


        <% for(let chat of data) { %>
            <tr>
                <td>
                    <%=chat._id%>
                </td>
                <td>
                    <%=chat.message%>
                </td>
                <td>
                    <%=chat.from%>
                </td>
                <td>
                    <%=chat.to%>
                </td>
                <td>
                    <%=chat.created_at%>
                </td>
            </tr>
            <% } %>
    </table>
</body>

</html>