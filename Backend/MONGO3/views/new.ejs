<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Chat</title>
</head>

<body>
    <h1>Create new chat</h1>
    <form method="post" action="/chats">
        <input name="from" type="text" placeholder="Enter your name">
        <br>
        <input name="to" type="text" placeholder="Whom you want to Send :">
        <br>
        <textarea cols="50" rows="10" name="message" id="" placeholder="Enter message here(maxlen 50) :"></textarea>

        <button>Send</button>
    </form>
</body>

</html>