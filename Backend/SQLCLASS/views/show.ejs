<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All users</title>
    <style>
        table,
        th,
        td {
            border: 1px solid black;
        }
    </style>
</head>

<body>
    <table>
        <tr>
            <th>Id</th>
            <th>Email</th>
            <th>username</th>
            <th>Password</th>
            <th></th>
            <th></th>
        </tr>
        <%for(let user of data){%>
            <tr>
                <td>
                    <%=user.id%>
                </td>
                <td>
                    <%=user.email%>
                </td>
                <td>
                    <%=user.username%>
                </td>
                <td>
                    <%=user.password%>
                </td>
                <td>
                    <form method="get" action="/users/<%=user.id%>/edit">
                        <button>Edit username</button>
                    </form>
                </td>
                <td>
                    <form method="POST" action="/users/<%=user.id%>?_method=DELETE">
                        <button>Delete user </button>
                    </form>
                </td>
            </tr>
            <%}%>
    </table>
</body>

</html>