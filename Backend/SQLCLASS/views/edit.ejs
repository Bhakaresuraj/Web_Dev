<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit username</title>
</head>

<body>
    <h1>Edit forms</h1>
    <h3>Data of user : <%= data.email %>
    </h3>

    <form method="POST" action="/users/<%=data.id%>?_method=PATCH">
        <textarea name="username"><%= data.username %></textarea>
        <input type="password" name="password" placeholder="Enter your password">
        <button>Edit</button>
    </form>

</body>

</html>